rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentAccountPath() {
      return /databases/$(database)/documents/accounts/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn() &&
        exists(currentAccountPath()) &&
        get(currentAccountPath()).data.keys().hasAny(['roles']) &&
        get(currentAccountPath()).data.roles is list &&
        get(currentAccountPath()).data.roles.hasAny(['admin']);
    }

    // Account: solo chi ha account.uid == uid autenticato (stesso modello concettuale degli items)
    function ownsAccount() {
      return signedIn() &&
        resource.data.keys().hasAny(['uid']) &&
        resource.data.uid == request.auth.uid;
    }

    function createsOwnAccount() {
      return signedIn() &&
        request.resource.data.keys().hasAny(['uid']) &&
        request.resource.data.uid == request.auth.uid;
    }

    // Solo gli admin possono modificare roles (niente auto-promozione a admin)
    function accountRolesUntouched() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles']);
    }

    function accountCreateRolesAllowed() {
      return !request.resource.data.keys().hasAny(['roles']) ||
        (
          request.resource.data.roles is list &&
          !request.resource.data.roles.hasAny(['admin'])
        );
    }

    function ownsItem() {
      return signedIn() &&
        resource.data.keys().hasAny(['uid']) &&
        resource.data.uid == request.auth.uid;
    }

    function createsOwnItem() {
      return signedIn() &&
        request.resource.data.keys().hasAny(['uid']) &&
        request.resource.data.uid == request.auth.uid;
    }

    function uidUnchanged() {
      return request.resource.data.keys().hasAny(['uid']) &&
        resource.data.keys().hasAny(['uid']) &&
        request.resource.data.uid == resource.data.uid;
    }

    match /accounts/{accountId} {
      allow read: if ownsAccount() || isAdmin();

      allow create: if isAdmin() ||
        (
          accountId == request.auth.uid &&
          createsOwnAccount() &&
          accountCreateRolesAllowed()
        );

      allow update: if isAdmin() ||
        (
          ownsAccount() &&
          uidUnchanged() &&
          accountRolesUntouched()
        );

      allow delete: if ownsAccount() || isAdmin();
    }

    match /items/{itemId} {
      allow read: if ownsItem() || isAdmin();

      allow create: if isAdmin() || createsOwnItem();

      allow update: if isAdmin() || (ownsItem() && uidUnchanged());

      allow delete: if ownsItem() || isAdmin();
    }
  }
}
